NODE_ENV=development
PORT=8081

# Frontend origin for CORS and email-verification redirects (use first URL if comma-separated: https://app.com,https://www.app.com)
FRONTEND_ORIGIN=http://localhost:8080

# Public URL of this API (no trailing slash) — use on production so verification links in email match your custom domain / HTTPS
# PUBLIC_API_URL=https://api.yourdomain.com

# Set to 1 behind a reverse proxy if you do not use NODE_ENV=production (optional)
# TRUST_PROXY=1

# MySQL (Aiven)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=hpc_alumni

# JWT (production: random string, 32+ characters — app refuses weak/default secrets when NODE_ENV=production)
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Email verification (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=secret
SMTP_FROM="HPC Alumni Association <no-reply@yourdomain.com>"

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8081/api/auth/google/callback

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=hpc-alumni

# scripts/seedAdmin.js — primary admin (defaults to sagormimmarriage@gmail.com if ADMIN_EMAIL unset)
# ADMIN_SEED_PASSWORD is required when creating that user; optional on later runs (only updates hash if set)
ADMIN_EMAIL=
ADMIN_SEED_PASSWORD=

# Primary admin email — cannot be deleted via User Management (default: sagormimmarriage@gmail.com)
PRIMARY_ADMIN_EMAIL=

